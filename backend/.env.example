PORT=3000
NODE_ENV=development
JWT_SECRET=change_me_minimum_16_chars

# Con docker-compose del repo (Postgres en Docker usa host 5433):
DATABASE_URL=postgresql://strava:strava@localhost:5433/strava_coach
# Postgres instalado en Windows (típico puerto 5432):
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/strava_coach

STRAVA_CLIENT_ID=167527
STRAVA_CLIENT_SECRET=your_strava_secret_here
STRAVA_REDIRECT_URI=http://localhost:3000/auth/callback
# Debe coincidir con el GET de validación en /webhook/strava (mismo host que arriba → …/webhook/strava)
STRAVA_VERIFY_TOKEN=your_webhook_verify_token
# Registrar webhook en Strava al arrancar: por defecto solo en NODE_ENV=production.
# En local con túnel HTTPS (ngrok, etc.) puedes forzar: STRAVA_AUTO_REGISTER_WEBHOOK=true
# STRAVA_AUTO_REGISTER_WEBHOOK=false

ANTHROPIC_API_KEY=your_anthropic_key_here

FRONTEND_URL=http://localhost:5173

# Opcional: 32+ caracteres para AES-256; si no se define, se deriva de JWT_SECRET
# TOKEN_ENCRYPTION_KEY=
